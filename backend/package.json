{
  "name": "grocerylist-backend",
  "version": "1.0.0",
  "description": "Family shopping list - serverless backend",
  "scripts": {
    "dev": "serverless offline start",
    "deploy": "serverless deploy",
    "deploy:prod": "serverless deploy --stage prod",
    "logs": "serverless logs -f getList --tail",
    "remove": "serverless remove",
    "dynamodb:install": "serverless dynamodb install",
    "db:init": "ts-node scripts/init-db.ts",
    "devdb": "npm run db:init && npm run dev",
    "test": "npx ts-node --project tsconfig.test.json tests/run-all.ts",
    "test:get": "npx ts-node --project tsconfig.test.json tests/01-getList.ts",
    "test:add": "npx ts-node --project tsconfig.test.json tests/02-addItem.ts",
    "test:update": "npx ts-node --project tsconfig.test.json tests/03-updateItem.ts",
    "test:delete": "npx ts-node --project tsconfig.test.json tests/04-deleteItem.ts"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.0.0",
    "@aws-sdk/lib-dynamodb": "^3.0.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.0",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "serverless": "^3.0.0",
    "serverless-dynamodb-local": "^0.2.40",
    "serverless-offline": "^13.0.0",
    "serverless-plugin-typescript": "^2.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  }
}
